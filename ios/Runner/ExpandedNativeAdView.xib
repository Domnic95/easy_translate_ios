                        <constraint firstItem="badge" firstAttribute="top" secondItem="cardBg" secondAttribute="top" constant="8" id="c-badge-t"/>
                        <constraint firstAttribute="trailing" secondItem="badge" secondAttribute="trailing" constant="8" id="c-badge-r"/>
