                <outlet property="advertiserLabel" destination="advertiser" id="ob-adv"/>
                <outlet property="bodyLabel" destination="body" id="ob-body"/>
                <outlet property="cardView" destination="cardBg" id="ob-card"/>
                <outlet property="ctaButton" destination="cta" id="ob-cta"/>
                <outlet property="headlineLabel" destination="headline" id="ob-head"/>
                <outlet property="iconImageView" destination="icon" id="ob-icon"/>
