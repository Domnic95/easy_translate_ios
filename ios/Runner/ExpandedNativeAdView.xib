                        <constraint firstItem="cta" firstAttribute="leading" secondItem="cardBg" secondAttribute="leading" constant="8" id="c-cta-l"/>
                        <constraint firstAttribute="trailing" secondItem="cta" secondAttribute="trailing" constant="8" id="c-cta-r"/>
