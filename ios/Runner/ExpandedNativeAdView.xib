                            <constraints>
                                <constraint firstAttribute="height" constant="180" id="media-h"/>
                            </constraints>
                        </view>
                        <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFill" translatesAutoresizingMaskIntoConstraints="NO" id="icon">
                            <rect key="frame" x="8" y="196" width="48" height="48"/>
                            <constraints>
                                <constraint firstAttribute="width" constant="48" id="icon-w"/>
                                <constraint firstAttribute="height" constant="48" id="icon-h"/>
                            </constraints>
                        </imageView>
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="headline">
                            <rect key="frame" x="64" y="200" width="303" height="17"/>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="14"/>
                            <nil key="textColor"/>
                            <nil key="highlightedColor"/>
                        </label>
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="advertiser">
                            <rect key="frame" x="64" y="223" width="303" height="14"/>
                            <fontDescription key="fontDescription" type="system" pointSize="11"/>
                            <nil key="textColor"/>
                            <nil key="highlightedColor"/>
                        </label>
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="body">
                            <rect key="frame" x="8" y="248" width="359" height="15"/>
                            <fontDescription key="fontDescription" type="system" pointSize="12"/>
                            <nil key="textColor"/>
                            <nil key="highlightedColor"/>
                        </label>
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="cta">
                            <rect key="frame" x="8" y="276" width="359" height="52"/>
                            <constraints>
                                <constraint firstAttribute="height" constant="52" id="cta-h"/>
                            </constraints>
                            <fontDescription key="fontDescription" type="systemSemibold" pointSize="16"/>
                            <state key="normal" title="Install">
                                <color key="titleColor" red="1" green="1" blue="1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            </state>
                        </button>
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="1000" horizontalCompressionResistancePriority="1000" text="Ad" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="badge">
                            <rect key="frame" x="345" y="8" width="22" height="14"/>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="9"/>
                            <color key="textColor" red="1" green="1" blue="1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            <color key="backgroundColor" red="0.231" green="0.51" blue="0.965" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            <nil key="highlightedColor"/>
                        </label>
                    </subviews>
                    <constraints>
                        <constraint firstItem="media" firstAttribute="top" secondItem="cardBg" secondAttribute="top" constant="8" id="c-media-t"/>
                        <constraint firstItem="media" firstAttribute="leading" secondItem="cardBg" secondAttribute="leading" constant="8" id="c-media-l"/>
                        <constraint firstAttribute="trailing" secondItem="media" secondAttribute="trailing" constant="8" id="c-media-r"/>
                        <constraint firstItem="icon" firstAttribute="top" secondItem="media" secondAttribute="bottom" constant="8" id="c-icon-t"/>
                        <constraint firstItem="icon" firstAttribute="leading" secondItem="cardBg" secondAttribute="leading" constant="8" id="c-icon-l"/>
                        <constraint firstItem="headline" firstAttribute="leading" secondItem="icon" secondAttribute="trailing" constant="8" id="c-head-l"/>
                        <constraint firstItem="headline" firstAttribute="top" secondItem="icon" secondAttribute="top" constant="2" id="c-head-t"/>
                        <constraint firstAttribute="trailing" secondItem="headline" secondAttribute="trailing" constant="8" id="c-head-r"/>
